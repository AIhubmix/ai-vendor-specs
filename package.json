{
  "name": "@aihubmix/ai-vendor-specs",
  "version": "1.20260609.0",
  "description": "Curated official OpenAPI / Discovery specifications for major AI providers, with overlay support for OpenAI-compatible vendors and daily upstream sync with drift detection.",
  "main": "scripts/overlay/apply.js",
  "exports": {
    ".": "./scripts/overlay/apply.js",
    "./manifest": "./manifest.json",
    "./manifest.json": "./manifest.json",
    "./overlay/apply": "./scripts/overlay/apply.js",
    "./notify": "./scripts/notify.js",
    "./upstream/*": "./upstream/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "sync": "bash scripts/sync-all.sh",
    "validate": "bash scripts/validate-all.sh",
    "manifest": "node scripts/build-manifest.js",
    "drift": "node scripts/check-drift.js",
    "detect-release": "node scripts/detect-release.js",
    "resolve": "node scripts/overlay/apply.js",
    "build-site": "node scripts/build-site.js",
    "report": "node scripts/report-changes.js"
  },
  "files": [
    "scripts/overlay/",
    "scripts/build-manifest.js",
    "scripts/notify.js",
    "upstream/",
    "manifest.json",
    "README.md",
    "README.zh-CN.md",
    "README.ja.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "cohere",
    "vertex",
    "azure",
    "bedrock",
    "xai",
    "grok",
    "openapi",
    "openapi-3",
    "discovery",
    "api-specs",
    "llm",
    "ai-gateway"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AIhubmix/ai-vendor-specs.git"
  },
  "homepage": "https://github.com/AIhubmix/ai-vendor-specs#readme",
  "bugs": {
    "url": "https://github.com/AIhubmix/ai-vendor-specs/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4"
  }
}
