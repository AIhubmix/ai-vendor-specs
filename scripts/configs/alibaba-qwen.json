{
  "provider": "alibaba-qwen",
  "protocol": "alibaba",
  "baseUrl": "https://dashscope.aliyuncs.com/api/v1",
  "docsUrl": "https://help.aliyun.com/zh/dashscope/developer-reference/api-details",
  "endpoints": [
    {
      "path": "/services/aigc/text-generation/generation",
      "method": "POST",
      "operationId": "createCompletion",
      "summary": "创建文本生成",
      "description": "通义千问文本生成接口",
      "parameters": [
        {
          "name": "Authorization",
          "in": "header",
          "required": true,
          "schema": { "type": "string" },
          "description": "API Key"
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["model", "input"],
              "properties": {
                "model": { "type": "string", "example": "qwen-turbo" },
                "input": {
                  "type": "object",
                  "properties": {
                    "messages": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "role": { "type": "string" },
                          "content": { "type": "string" }
                        }
                      }
                    }
                  }
                },
                "parameters": {
                  "type": "object",
                  "properties": {
                    "result_format": { "type": "string", "enum": ["text", "message"] }
                  }
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "成功响应",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "output": {
                    "type": "object",
                    "properties": {
                      "text": { "type": "string" }
                    }
                  },
                  "usage": {
                    "type": "object",
                    "properties": {
                      "input_tokens": { "type": "integer" },
                      "output_tokens": { "type": "integer" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
