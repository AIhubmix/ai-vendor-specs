# ai-vendor-specs 本地配置示例
#
# 复制为 .env.local(.gitignore 已屏蔽)后编辑。CI 走 GitHub Secrets,
# 不要把真实 URL 提交进仓库。

# ── Webhook 通知 ────────────────────────────────────────────────────────────
#
# drift check / sync 发现异常时推送通知。未配置则静默 no-op,fork 用户零侵入。
# 通道按 URL 域名自动识别(wxwork / slack / discord / generic)。

# 企业微信群机器人:
# AVS_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# Slack incoming webhook:
# AVS_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXX

# Discord webhook:
# AVS_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXX/YYYYY

# 任意 POST 端点(generic 兜底,body 是 {text, message}):
# AVS_WEBHOOK_URL=https://example.com/hooks/avs

# 显式指定通道类型(默认自动识别,通常不需要):
# AVS_WEBHOOK_TYPE=wxwork
